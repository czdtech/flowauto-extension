{
  "manifest_version": 3,
  "name": "FlowAuto",
  "version": "1.0.0",
  "description": "Batch automation for Google Flow — queue prompts, auto-download, chain mode, AI engine, and more.",
  "permissions": ["storage", "downloads", "tabs", "activeTab", "sidePanel", "scripting"],
  "host_permissions": ["https://labs.google/*", "https://api.telegram.org/*", "https://discord.com/api/webhooks/*"],
  "action": {
    "default_title": "FlowAuto"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://labs.google/*"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel/index.html"
  }
}

